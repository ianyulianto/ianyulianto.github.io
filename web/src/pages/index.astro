---
import BookLayout from "../layouts/BookLayout.astro";
import { loadBook } from "../lib/parseBook";
import { loadBookUpdates } from "../lib/bookUpdates";

const book = loadBook();
const updates = loadBookUpdates();
const { meta, parts } = book;
const firstHref = parts.length > 0 ? `/part/${parts[0].slug}` : null;
const pageTitle = meta.title;
const description = `${meta.tagline} — ${meta.author}`;
const newCount = updates.newBlocks.length;
const updatedCount = updates.updatedBlocks.length;
const changeCount = newCount + updatedCount;
---

<BookLayout title={pageTitle} description={description} lang={meta.language}>
  <main class="cover">
    <div class="cover-inner">
      <p class="author">{meta.author}</p>
      <h1 class="title">{meta.title}</h1>
      <p class="tagline">{meta.tagline}</p>

      {firstHref ? (
        <div class="actions">
          <a class="btn primary" href={firstHref}>Mulai baca</a>
          <a class="btn ghost" href="/acak">Baca acak</a>
          <a class="btn ghost" href="/daftar">Daftar isi</a>
        </div>
      ) : (
        <div class="waiting">
          <p>
            Belum ada isi buku. Isi <code>web/content/book.yaml</code>,
            lalu push ke <code>master</code>.
          </p>
        </div>
      )}

      {parts.length > 0 && (
        <p class="meta-line">
          {parts.length} bagian
          {changeCount > 0 && (
            <>
              {" · "}
              <a class="new-link" href="/daftar">
                {newCount > 0 && updatedCount > 0
                  ? `${newCount} blok baru · ${updatedCount} diubah`
                  : newCount > 0
                    ? `${newCount} blok baru`
                    : `${updatedCount} blok diubah`}
              </a>
            </>
          )}
        </p>
      )}
    </div>
  </main>
</BookLayout>

<style>
  .cover {
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: var(--pad-y) var(--pad-x);
  }

  .cover-inner {
    width: min(100%, 26rem);
    text-align: center;
    animation: rise 0.9s ease both;
  }

  .author {
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
    animation: rise 0.9s ease 0.08s both;
  }

  .title {
    font-size: var(--fs-display);
    margin-bottom: 1rem;
    text-wrap: balance;
    animation: rise 0.9s ease 0.16s both;
  }

  .tagline {
    color: var(--ink-soft);
    margin-bottom: 2.25rem;
    text-wrap: pretty;
    animation: rise 0.9s ease 0.24s both;
  }

  .actions {
    display: grid;
    gap: 0.75rem;
    animation: rise 0.9s ease 0.32s both;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.8rem 1.25rem;
    border-radius: 999px;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
  }

  .btn.primary {
    background: var(--ink);
    color: var(--bg);
  }

  .btn.primary:hover {
    background: var(--accent);
    color: white;
  }

  .btn.ghost {
    color: var(--ink-soft);
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.35);
  }

  .btn.ghost:hover {
    color: var(--ink);
    border-color: color-mix(in srgb, var(--ink) 25%, transparent);
  }

  .waiting {
    text-align: left;
    padding: 1rem 1.1rem;
    border: 1px dashed var(--line);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.35);
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .waiting code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.85em;
    color: var(--ink);
  }

  .meta-line {
    margin-top: 1.75rem;
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    color: var(--ink-faint);
  }

  .new-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .new-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
