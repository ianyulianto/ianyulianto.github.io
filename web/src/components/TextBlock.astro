---
import NewBadge from "./NewBadge.astro";
import type { UpdateStatus } from "../lib/bookUpdates";
import type { PoetrySequence } from "../lib/parseBook";

interface Props {
  kind: "prose" | "poetry" | "divider";
  lines: string[];
  blockId?: string;
  updateStatus?: UpdateStatus | null;
  previousPreview?: string | null;
  changePreview?: string | null;
  poetrySequence?: PoetrySequence | null;
}

const {
  kind,
  lines,
  blockId,
  updateStatus = null,
  previousPreview = null,
  changePreview = null,
  poetrySequence = null,
} = Astro.props;

const kindLabel = kind === "poetry" ? "puisi" : kind === "prose" ? "prosa" : "";
const inSequence = kind === "poetry" && poetrySequence !== null;
const seqLabel = inSequence
  ? `Puisi ${poetrySequence.index} dari ${poetrySequence.total}`
  : null;
---

{
  kind === "divider" ? (
    <div class="block divider" aria-hidden="true">
      <span>∗ ∗ ∗</span>
    </div>
  ) : (
    <div
      class:list={[
        "block-wrap",
        updateStatus,
        inSequence && "poetry-seq",
        inSequence && poetrySequence.index === 1 && "poetry-seq-first",
        inSequence && poetrySequence.index === poetrySequence.total && "poetry-seq-last",
      ]}
      id={blockId}
      data-poetry-index={inSequence ? poetrySequence.index : undefined}
      data-poetry-total={inSequence ? poetrySequence.total : undefined}
    >
      {updateStatus && (
        <div class="block-meta">
          <NewBadge status={updateStatus} />
          {kindLabel && <span class="kind-tag">{kindLabel}</span>}
          {updateStatus === "updated" && previousPreview && changePreview && (
            <p class="change-note">
              <span class="change-label">Perubahan</span>
              <span class="change-text">
                “{previousPreview}” → “{changePreview}”
              </span>
            </p>
          )}
        </div>
      )}

      {kind === "poetry" ? (
        <figure class="block poetry" aria-label={seqLabel ?? undefined}>
          {inSequence && (
            <figcaption class="poetry-mark">
              <span class="poetry-mark-line" aria-hidden="true" />
              <span class="poetry-mark-num">{poetrySequence.index}</span>
              <span class="poetry-mark-line" aria-hidden="true" />
              <span class="visually-hidden">{seqLabel}</span>
            </figcaption>
          )}
          {lines.map((line) => (
            <span class="verse-line">{line || "\u00A0"}</span>
          ))}
        </figure>
      ) : (
        <div class="block prose">
          {lines.map((line) => (
            <p>{line}</p>
          ))}
        </div>
      )}
    </div>
  )
}

<style>
  .block-wrap {
    display: grid;
    gap: 0.55rem;
  }

  .block-wrap.new,
  .block-wrap.updated {
    padding: 0.65rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 0.35rem;
  }

  .block-wrap.new {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }

  .block-wrap.updated {
    background: color-mix(in srgb, var(--ink) 3.5%, transparent);
  }

  .block-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.55rem;
  }

  .kind-tag {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .change-note {
    flex: 1 1 100%;
    display: grid;
    gap: 0.15rem;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--ink-faint);
  }

  .change-label {
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
    font-size: 0.65rem;
  }

  .change-text {
    color: var(--ink-soft);
    font-style: italic;
  }

  .block {
    margin: 0;
  }

  .prose {
    display: grid;
    gap: 1.1em;
  }

  .prose p {
    text-wrap: pretty;
  }

  .poetry {
    display: grid;
    gap: 0.15em;
    justify-items: start;
    max-width: 22rem;
    margin-inline: auto;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 3.8vw, 1.2rem);
    line-height: var(--lh-poetry);
    font-weight: 500;
  }

  /* Consecutive poetry run (>2): clearer poem boundaries + ordinal cue */
  .poetry-seq {
    padding-block: 0.35rem 0.55rem;
  }

  .poetry-seq-first {
    padding-block-start: 0.15rem;
  }

  .poetry-seq-last {
    padding-block-end: 0.15rem;
  }

  .poetry-seq .poetry {
    gap: 0.2em;
    padding-block: 0.35rem 0.85rem;
  }

  .poetry-mark {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.65rem;
    width: min(100%, 14rem);
    margin: 0 auto 0.85rem;
    justify-self: center;
  }

  .poetry-mark-line {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--ink) 18%, transparent),
      transparent
    );
  }

  .poetry-mark-num {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .verse-line {
    display: block;
    white-space: pre-wrap;
  }

  .divider {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0;
    color: var(--ink-faint);
    font-family: var(--font-display);
    letter-spacing: 0.35em;
    font-size: 0.95rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
