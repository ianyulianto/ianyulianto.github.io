---
import NewBadge from "./NewBadge.astro";
import type { UpdateStatus } from "../lib/bookUpdates";

interface Props {
  kind: "prose" | "poetry" | "divider";
  lines: string[];
  blockId?: string;
  updateStatus?: UpdateStatus | null;
  previousPreview?: string | null;
  changePreview?: string | null;
}

const {
  kind,
  lines,
  blockId,
  updateStatus = null,
  previousPreview = null,
  changePreview = null,
} = Astro.props;

const kindLabel = kind === "poetry" ? "puisi" : kind === "prose" ? "prosa" : "";
---

{
  kind === "divider" ? (
    <div class="block divider" aria-hidden="true">
      <span>∗ ∗ ∗</span>
    </div>
  ) : (
    <div class:list={["block-wrap", updateStatus]} id={blockId}>
      {updateStatus && (
        <div class="block-meta">
          <NewBadge status={updateStatus} />
          {kindLabel && <span class="kind-tag">{kindLabel}</span>}
          {updateStatus === "updated" && previousPreview && changePreview && (
            <p class="change-note">
              <span class="change-label">Perubahan</span>
              <span class="change-text">
                “{previousPreview}” → “{changePreview}”
              </span>
            </p>
          )}
        </div>
      )}

      {kind === "poetry" ? (
        <figure class="block poetry">
          {lines.map((line) => (
            <span class="verse-line">{line || "\u00A0"}</span>
          ))}
        </figure>
      ) : (
        <div class="block prose">
          {lines.map((line) => (
            <p>{line}</p>
          ))}
        </div>
      )}
    </div>
  )
}

<style>
  .block-wrap {
    display: grid;
    gap: 0.55rem;
  }

  .block-wrap.new,
  .block-wrap.updated {
    padding: 0.65rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 0.35rem;
  }

  .block-wrap.new {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }

  .block-wrap.updated {
    background: color-mix(in srgb, var(--ink) 3.5%, transparent);
  }

  .block-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.55rem;
  }

  .kind-tag {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .change-note {
    flex: 1 1 100%;
    display: grid;
    gap: 0.15rem;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--ink-faint);
  }

  .change-label {
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
    font-size: 0.65rem;
  }

  .change-text {
    color: var(--ink-soft);
    font-style: italic;
  }

  .block {
    margin: 0;
  }

  .prose {
    display: grid;
    gap: 1.1em;
  }

  .prose p {
    text-wrap: pretty;
  }

  .poetry {
    display: grid;
    gap: 0.15em;
    justify-items: start;
    max-width: 22rem;
    margin-inline: auto;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 3.8vw, 1.2rem);
    line-height: var(--lh-poetry);
    font-weight: 500;
  }

  .verse-line {
    display: block;
    white-space: pre-wrap;
  }

  .divider {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0;
    color: var(--ink-faint);
    font-family: var(--font-display);
    letter-spacing: 0.35em;
    font-size: 0.95rem;
  }
</style>
