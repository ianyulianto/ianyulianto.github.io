---
import Container from "./Container.astro";
---
<footer class="site-footer">
  <Container>
    <div class="footer-grid">
      
      {/* 1. Brand Section */}
      <div class="footer-brand">
        <span class="brand-name">Samya Studio</span>
        <p class="brand-tagline">Refining digital ideas into clarity. Building products that matter.</p>
      </div>

      {/* 2. Links Section */}
      <div class="footer-links">
        <h4 class="footer-heading">Explore</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/case-studies">Work</a></li>
          <li><a href="/insights">Insights</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      
      {/* 3. Contact Section */}
      <div class="footer-contact">
        <h4 class="footer-heading">Connect</h4>
        <ul class="contact-list">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:samya.studio.id@gmail.com">samya.studio.id@gmail.com</a>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.05 12.05 0 0 0 .57 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.03 12.03 0 0 0 2.81.57A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="https://wa.me/628113078217">+62 8113078217</a>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Surabaya, Indonesia</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Samya Studio. All rights reserved.</p>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    background-color: #f8fafc; /* Slate 50 */
    color: #64748b; /* Slate 500 */
    padding: var(--s-6) 0 var(--s-4);
    border-top: 1px solid #e2e8f0;
    margin-top: 0;
  }
  
  .footer-grid {
    display: grid;
    gap: var(--s-5);
    margin-bottom: var(--s-6);
  }
  
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1.5fr;
      gap: var(--s-6);
    }
  }

  .brand-name {
    display: block;
    font-size: var(--h3);
    font-weight: 700;
    color: #0f172a; /* Slate 900 */
    margin-bottom: var(--s-2);
  }
  .brand-tagline {
    font-size: var(--body);
    line-height: 1.6;
    max-width: 320px;
  }
  
  .footer-heading {
    color: #0f172a; /* Slate 900 */
    font-size: var(--body);
    font-weight: 600;
    margin-bottom: var(--s-3);
    margin-top: 0;
  }
  
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  li {
    margin-bottom: var(--s-2);
  }
  
  a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  a:hover {
    color: var(--primary); /* Primary Blue on hover */
  }
  
  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--s-2);
  }
  
  .icon {
    flex-shrink: 0;
    margin-top: 4px; 
    color: var(--primary); /* Primary Blue */
  }

  .footer-bottom {
    padding-top: var(--s-4);
    border-top: 1px solid #e2e8f0;
    text-align: center;
    font-size: var(--small);
  }
</style>
