---
import BookLayout from "../../layouts/BookLayout.astro";
import TextBlock from "../../components/TextBlock.astro";
import PartNav from "../../components/PartNav.astro";
import PartIllustration from "../../components/PartIllustration.astro";
import { annotatePoetrySequences, loadBook } from "../../lib/parseBook";
import { loadBookUpdates } from "../../lib/bookUpdates";

export function getStaticPaths() {
  const book = loadBook();
  const updates = loadBookUpdates();
  return book.parts.map((part, i) => ({
    params: { slug: part.slug },
    props: {
      part,
      prev: book.parts[i - 1] ?? null,
      next: book.parts[i + 1] ?? null,
      total: book.parts.length,
      meta: book.meta,
      byBlockKey: updates.byBlockKey,
    },
  }));
}

const { part, prev, next, total, meta, byBlockKey } = Astro.props;
const blocks = annotatePoetrySequences(part.blocks);
---

<BookLayout
  title={`${part.title} — ${meta.title}`}
  description={part.preview || meta.tagline}
  lang={meta.language}
>
  <div class="reader">
    <header class="reader-head">
      <a class="crumb" href="/daftar">Daftar isi</a>
      <p class="part-label">{part.label}</p>
      <h1>{part.title}</h1>
      {
        part.illustrationSvg && (
          <PartIllustration svg={part.illustrationSvg} variant="chapter" class="chapter-art" />
        )
      }
    </header>

    <article class="content">
      {blocks.map((block, blockIndex) => {
        const key = `${part.slug}:${blockIndex}`;
        const update = byBlockKey[key] ?? null;
        return (
          <TextBlock
            kind={block.kind}
            lines={block.lines}
            blockId={`b-${part.slug}-${blockIndex}`}
            updateStatus={update?.status ?? null}
            previousPreview={update?.previousPreview ?? null}
            changePreview={update?.status === "updated" ? update.preview : null}
            poetrySequence={block.poetrySequence}
          />
        );
      })}
    </article>

    <PartNav
      current={part.index}
      total={total}
      prevHref={prev ? `/part/${prev.slug}` : null}
      nextHref={next ? `/part/${next.slug}` : null}
    />
  </div>
</BookLayout>

<style>
  .reader {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .reader-head {
    width: min(100%, var(--read-max));
    margin: 0 auto;
    padding: var(--pad-y) var(--pad-x) 1.5rem;
  }

  .crumb {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    color: var(--ink-faint);
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .crumb:hover {
    color: var(--accent);
  }

  .part-label {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--fs-small);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: var(--fs-title);
    text-wrap: balance;
  }

  .reader-head :global(.chapter-art) {
    margin-top: 1.35rem;
  }

  .content {
    width: min(100%, var(--read-max));
    margin: 0 auto;
    padding: 0.5rem var(--pad-x) 2.5rem;
    display: grid;
    gap: 1.75rem;
    flex: 1;
    animation: fade 0.55s ease both;
  }

  /* Extra breath between poems in a long consecutive run */
  .content :global(.poetry-seq + .poetry-seq) {
    margin-top: 0.85rem;
  }

  @keyframes fade {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
