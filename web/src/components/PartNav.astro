---
interface Props {
  prevHref?: string | null;
  nextHref?: string | null;
  current: number;
  total: number;
  listHref?: string;
}

const {
  prevHref = null,
  nextHref = null,
  current,
  total,
  listHref = "/daftar",
} = Astro.props;
---

<nav class="part-nav" aria-label="Navigasi bagian">
  <a class:list={["nav-btn", { disabled: !prevHref }]} href={prevHref || "#"} aria-disabled={!prevHref}>
    ← Sebelumnya
  </a>
  <a class="nav-mid" href={listHref}>
    {current} / {total}
  </a>
  <a class:list={["nav-btn", "next", { disabled: !nextHref }]} href={nextHref || "#"} aria-disabled={!nextHref}>
    Berikutnya →
  </a>
</nav>

<style>
  .part-nav {
    position: sticky;
    bottom: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.5rem;
    align-items: center;
    padding: 0.75rem var(--pad-x) calc(0.75rem + var(--safe-bottom));
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--line);
    font-family: var(--font-ui);
    font-size: var(--fs-small);
  }

  .nav-btn,
  .nav-mid {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.55rem 0.75rem;
    border-radius: 0.75rem;
    text-decoration: none;
    color: var(--ink);
  }

  .nav-btn {
    background: var(--accent-soft);
    font-weight: 560;
  }

  .nav-btn.next {
    justify-self: end;
  }

  .nav-btn:hover:not(.disabled) {
    background: color-mix(in srgb, var(--accent) 22%, white);
  }

  .nav-btn.disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .nav-mid {
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
</style>
